# Environment Variables for ASIS
# Copy this file to .env and fill in your actual values

# Google Gemini API Key
# Get yours from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Stellar Testnet Secret Key
# Generate a new keypair at: https://laboratory.stellar.org/#account-creator?network=test
# WARNING: Never use mainnet keys in test environments!
STELLAR_SECRET_KEY=your_stellar_testnet_secret_key_here